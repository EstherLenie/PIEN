@startuml modification
actor Enseignant
participant "Application cliente" as Client
participant "Service de gestion\ndes fichiers" as Files
participant "Service de gestion\ndes cours" as Courses
participant "Base de données" as DB
participant "Bus d’événements" as Bus

Enseignant -> Client : Modifier le contenu
Client -> Files : Upload nouveaux fichiers
Files -> Client : URLs des fichiers
Client -> Client : Mise à jour du contenu
Client -> Courses : Envoi du contenu mis à jour
Courses -> Files : Suppression des fichiers obsolètes
Courses -> DB : Sauvegarde nouvelle version
Courses -> Bus : Événement publication (si applicable)
@enduml
