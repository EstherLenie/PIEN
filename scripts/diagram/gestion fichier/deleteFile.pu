@startuml deletes
actor Utilisateur
participant "Passerelle API" as API
participant "Backend Fichiers" as Backend
database "MongoDB" as DB
participant "Cache Redis" as Cache
participant "S3" as Stockage

Utilisateur -> API : Requête delete + URL du fichier
API -> API : Valide jeton et droits
API -> Backend : Transmet requête validée
Backend -> DB : Vérifie existence du fichier
alt Fichier existe
    Backend -> Stockage : Supprime fichier
    Stockage --> Backend : Confirmation
    Backend -> DB : Supprime métadonnées
    Backend -> Cache : Supprime du cache
    Backend --> API : Confirmation suppression
else Fichier inexistant
    Backend --> API : Erreur
end
API --> Utilisateur : Résultat suppression
@enduml
